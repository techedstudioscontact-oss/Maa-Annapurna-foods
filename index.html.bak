<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Maa Annapurna Foods | Premium Local Grocery</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts: Plus Jakarta Sans for a hyper-modern agency look -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>

    <!-- AOS Animation Library -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            900: '#064E3B', /* Deep Forest Green */
                            800: '#065F46',
                            DEFAULT: '#047857',
                            100: '#D1FAE5',
                            50: '#ECFDF5',
                        },
                        accent: {
                            DEFAULT: '#BEF264', /* Vibrant Lime/Chartreuse */
                            hover: '#A3E635',
                        },
                        surface: '#F8F9F6', /* Warm off-white */
                    },
                    boxShadow: {
                        'glow': '0 0 40px -10px rgba(190, 242, 100, 0.5)',
                        'glass': '0 8px 32px 0 rgba(0, 0, 0, 0.05)',
                        'float': '0 20px 40px -10px rgba(6, 78, 59, 0.15)',
                    }
                }
            }
        }
    </script>

    <style>
        /* Custom Noise Texture Overlay */
        .noise-bg {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            pointer-events: none;
            z-index: 9999;
            opacity: 0.03;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #F8F9F6; }
        ::-webkit-scrollbar-thumb { background: #064E3B; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #047857; }

        /* Floating Animation */
        @keyframes float-slow {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-15px) rotate(1deg); }
        }
        .animate-float-slow { animation: float-slow 6s ease-in-out infinite; }

        /* Image Masking / Blob */
        .blob-mask {
            clip-path: polygon(44% 4%, 81% 12%, 96% 45%, 85% 82%, 48% 97%, 14% 83%, 3% 48%, 14% 13%);
            transition: clip-path 0.5s ease;
        }
        .blob-mask:hover {
            clip-path: polygon(50% 0%, 88% 15%, 100% 50%, 86% 87%, 50% 100%, 15% 88%, 0% 50%, 14% 13%);
        }

        body { background-color: #F8F9F6; overflow-x: hidden; }

        /* Smooth Navbar Transition */
        #nav-island { transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
        .nav-scrolled { padding-top: 0.5rem; padding-bottom: 0.5rem; background-color: rgba(255, 255, 255, 0.9); box-shadow: 0 10px 30px -10px rgba(0,0,0,0.1); }
    </style>
</head>
<body class="font-sans text-gray-800 antialiased selection:bg-accent selection:text-brand-900 relative">
    
    <div class="noise-bg"></div>

    <!-- Floating Island Navigation -->
    <div class="fixed top-4 md:top-6 inset-x-0 z-50 flex justify-center px-4" data-aos="fade-down" data-aos-duration="1000">
        <nav id="nav-island" class="w-full max-w-5xl bg-white/70 backdrop-blur-xl border border-white/40 shadow-glass rounded-full px-5 py-3 md:px-6 md:py-4 flex justify-between items-center relative z-50">
            <!-- Logo -->
            <div class="flex items-center gap-2 cursor-pointer group">
                <div class="w-9 h-9 md:w-10 md:h-10 bg-brand-900 text-accent rounded-full flex items-center justify-center transform group-hover:rotate-12 transition-transform shadow-md">
                    <i class="ph-fill ph-basket text-lg md:text-xl"></i>
                </div>
                <span class="font-bold text-lg md:text-xl tracking-tight text-brand-900">Maa Annapurna.</span>
            </div>
            
            <!-- Desktop Links -->
            <div class="hidden md:flex items-center gap-8">
                <a href="#why-us" class="text-sm font-semibold text-gray-600 hover:text-brand-900 transition-colors">Why Us</a>
                <a href="#products" class="text-sm font-semibold text-gray-600 hover:text-brand-900 transition-colors">Products</a>
                <a href="#trust" class="text-sm font-semibold text-gray-600 hover:text-brand-900 transition-colors">Our Story</a>
            </div>

            <!-- Desktop CTAs & Mobile Toggle -->
            <div class="flex items-center gap-3 md:gap-4">
                <a href="#app" class="hidden md:flex items-center gap-2 text-sm font-bold text-brand-900 hover:text-brand-DEFAULT transition-colors">
                    Get App <i class="ph-bold ph-arrow-up-right"></i>
                </a>
                <a href="#products" class="hidden md:block bg-accent text-brand-900 px-6 py-2.5 rounded-full text-sm font-bold hover:bg-accent-hover transition-all transform hover:scale-105 shadow-glow">
                    Shop Now
                </a>
                
                <!-- Mobile Menu Button -->
                <button id="mobile-menu-btn" class="md:hidden w-10 h-10 flex items-center justify-center rounded-full bg-brand-50 text-brand-900 focus:outline-none hover:bg-brand-100 transition-colors">
                    <i class="ph-bold ph-list text-xl" id="menu-icon"></i>
                </button>
            </div>
        </nav>
        
        <!-- Mobile Dropdown Menu -->
        <div id="mobile-menu" class="fixed top-20 left-4 right-4 bg-white/95 backdrop-blur-2xl rounded-[2rem] shadow-2xl p-6 border border-white/50 opacity-0 pointer-events-none transform -translate-y-4 transition-all duration-300 z-40 flex flex-col gap-4">
            <a href="#why-us" class="mobile-link text-lg font-bold text-gray-800 hover:text-brand-DEFAULT px-4 py-2 rounded-xl hover:bg-brand-50 transition-colors">Why Choose Us</a>
            <a href="#products" class="mobile-link text-lg font-bold text-gray-800 hover:text-brand-DEFAULT px-4 py-2 rounded-xl hover:bg-brand-50 transition-colors">Categories</a>
            <a href="#trust" class="mobile-link text-lg font-bold text-gray-800 hover:text-brand-DEFAULT px-4 py-2 rounded-xl hover:bg-brand-50 transition-colors">Our Story</a>
            <hr class="border-gray-100 my-2">
            <a href="#app" class="mobile-link bg-brand-900 text-white text-center px-6 py-4 rounded-xl text-lg font-bold shadow-float flex items-center justify-center gap-2">
                Download App <i class="ph-bold ph-download-simple"></i>
            </a>
        </div>
    </div>

    <!-- 1. HERO SECTION (Immersive & Bold) -->
    <section class="relative min-h-[100svh] flex items-center pt-32 pb-20 overflow-hidden">
        <!-- Abstract Background Shapes -->
        <div class="absolute top-[-10%] right-[-5%] w-[60vw] h-[60vw] max-w-[600px] max-h-[600px] bg-brand-100 rounded-full mix-blend-multiply filter blur-[80px] opacity-70 animate-float-slow z-0"></div>
        <div class="absolute bottom-[-10%] left-[-10%] w-[50vw] h-[50vw] max-w-[500px] max-h-[500px] bg-accent/20 rounded-full mix-blend-multiply filter blur-[80px] opacity-70 animate-float-slow z-0" style="animation-delay: 2s;"></div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
                
                <!-- Typography Column -->
                <div class="lg:col-span-7 flex flex-col items-start pt-10 lg:pt-0" data-aos="fade-right" data-aos-duration="1200">
                    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-gray-200 bg-white/60 backdrop-blur-md mb-6 md:mb-8 shadow-sm">
                        <span class="relative flex h-2.5 w-2.5">
                          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
                          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-brand-DEFAULT"></span>
                        </span>
                        <span class="text-[10px] md:text-xs font-bold uppercase tracking-widest text-brand-900">Serving Your Community</span>
                    </div>
                    
                    <h1 class="text-[2.75rem] sm:text-6xl lg:text-[5.5rem] font-extrabold text-brand-900 leading-[1.05] tracking-tighter mb-6">
                        Everything you need.<br>
                        <span class="relative inline-block">
                            <span class="relative z-10 text-transparent bg-clip-text bg-gradient-to-r from-brand-900 to-brand-DEFAULT">Under one roof.</span>
                            <!-- Highlight stroke behind text -->
                            <svg class="absolute w-full h-full left-0 bottom-[-5%] md:bottom-[-10%] z-0" viewBox="0 0 400 60" preserveAspectRatio="none">
                                <path d="M0 45 Q 200 15, 400 45 L 400 60 L 0 60 Z" fill="#BEF264" opacity="0.4"></path>
                            </svg>
                        </span>
                    </h1>
                    
                    <p class="text-base md:text-xl text-gray-600 mb-8 md:mb-10 max-w-lg font-medium leading-relaxed">
                        Premium groceries, home appliances, and daily essentials. Everything you need, delivered with trust.
                    </p>
                    
                    <div class="flex flex-col sm:flex-row flex-wrap items-start sm:items-center gap-4 sm:gap-6 w-full sm:w-auto">
                        <a href="#products" class="w-full sm:w-auto bg-brand-900 text-white px-8 py-4 rounded-full text-lg font-bold hover:bg-brand-800 transition-all shadow-float flex justify-center items-center gap-3 group">
                            Explore Store
                            <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center group-hover:translate-x-1 transition-transform">
                                <i class="ph-bold ph-arrow-right"></i>
                            </div>
                        </a>
                        <div class="flex items-center gap-3 px-2 py-2">
                            <div class="flex -space-x-3">
                                <img class="w-10 h-10 rounded-full border-2 border-surface object-cover" src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&q=80" alt="Customer">
                                <img class="w-10 h-10 rounded-full border-2 border-surface object-cover" src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&q=80" alt="Customer">
                                <div class="w-10 h-10 rounded-full border-2 border-surface bg-accent flex items-center justify-center text-brand-900 font-bold text-xs">+2k</div>
                            </div>
                            <div class="text-xs md:text-sm font-semibold text-brand-900 leading-tight">
                                Happy<br>Neighbors
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Visual Composition Column -->
                <div class="lg:col-span-5 relative h-[400px] md:h-[600px] w-full mt-10 lg:mt-0" data-aos="zoom-in" data-aos-duration="1500" data-aos-delay="200">
                    <div class="absolute inset-0 flex items-center justify-center">
                        <!-- Main Image in Blob -->
                        <div class="relative w-[90%] md:w-full h-[90%] md:h-full max-w-[450px] max-h-[450px] animate-float-slow blob-mask overflow-hidden shadow-2xl bg-brand-100">
                            <img src="assets/hero.png" alt="Maa Annapurna Store" class="w-full h-full object-cover scale-110 hover:scale-100 transition-transform duration-700">
                            <!-- Overlay gradient -->
                            <div class="absolute inset-0 bg-gradient-to-t from-brand-900/40 to-transparent"></div>
                        </div>
                        
                        <!-- Floating Badge 1 -->
                        <div class="absolute top-[5%] md:top-[10%] left-0 md:left-[-5%] bg-white/90 backdrop-blur-md px-4 md:px-6 py-3 md:py-4 rounded-2xl md:rounded-3xl shadow-xl flex items-center gap-3 animate-float-slow" style="animation-delay: 1s;" data-aos="fade-right" data-aos-delay="600">
                            <div class="w-10 h-10 md:w-12 md:h-12 bg-accent rounded-full flex items-center justify-center text-xl md:text-2xl">🏠</div>
                            <div>
                                <div class="text-[10px] md:text-xs text-gray-500 font-bold uppercase tracking-wider">Premium Selection</div>
                                <div class="text-xs md:text-sm font-extrabold text-brand-900">Total Variety</div>
                            </div>
                        </div>

                        <!-- Floating Badge 2 -->
                        <div class="absolute bottom-[5%] md:bottom-[15%] right-0 md:right-[-10%] bg-brand-900 text-white px-4 md:px-6 py-3 md:py-4 rounded-2xl md:rounded-3xl shadow-xl flex items-center gap-3 animate-float-slow" style="animation-delay: 1.5s;" data-aos="fade-left" data-aos-delay="800">
                            <div class="w-10 h-10 md:w-12 md:h-12 bg-white/10 rounded-full flex items-center justify-center">
                                <i class="ph-bold ph-moped text-xl md:text-2xl text-accent"></i>
                            </div>
                            <div>
                                <div class="text-[10px] md:text-xs text-brand-100 font-medium uppercase tracking-wider">Delivery</div>
                                <div class="text-xs md:text-sm font-extrabold">Under 30 Mins</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 2. WHY CHOOSE US (Bento Box Grid) -->
    <section id="why-us" class="py-20 md:py-32 relative z-10 bg-surface">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="mb-12 md:mb-16 text-center md:text-left" data-aos="fade-up">
                <h2 class="text-xs md:text-sm font-bold tracking-widest uppercase text-brand-DEFAULT mb-3">The Annapurna Advantage</h2>
                <h3 class="text-3xl md:text-5xl font-extrabold text-brand-900 tracking-tight leading-tight">Why the community <br class="hidden md:block">trusts us.</h3>
            </div>

            <!-- Bento Grid -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 auto-rows-[auto] md:auto-rows-[250px]">
                
                <!-- Box 1 (Large) -->
                <div class="md:col-span-2 bg-white rounded-[2rem] p-8 md:p-10 border border-gray-100 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_20px_40px_rgb(0,0,0,0.08)] transition-all duration-500 flex flex-col justify-between group overflow-hidden relative" data-aos="fade-up" data-aos-delay="100">
                    <div class="absolute right-[-10%] top-[-20%] w-64 h-64 bg-accent/20 rounded-full blur-3xl group-hover:bg-accent/40 transition-colors duration-500"></div>
                    <div class="relative z-10">
                        <div class="w-14 h-14 bg-brand-50 rounded-2xl flex items-center justify-center mb-6">
                            <i class="ph-fill ph-storefront text-3xl text-brand-DEFAULT"></i>
                        </div>
                        <h4 class="text-2xl font-bold text-brand-900 mb-3">Locally Trusted Store</h4>
                        <p class="text-gray-600 font-medium max-w-md">Serving the community with honesty and care for years. We aren't just a store; we are your neighbors.</p>
                    </div>
                    <i class="ph-bold ph-arrow-up-right absolute bottom-8 right-8 text-3xl text-gray-200 group-hover:text-brand-DEFAULT transition-colors hidden md:block"></i>
                </div>

                <!-- Box 2 (Small) -->
                <div class="bg-brand-900 rounded-[2rem] p-8 md:p-10 shadow-lg flex flex-col justify-between relative overflow-hidden group text-white" data-aos="fade-up" data-aos-delay="200">
                    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1596199050105-6d5d32222916?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80')] opacity-20 mix-blend-overlay object-cover group-hover:opacity-30 transition-opacity duration-500"></div>
                    <div class="absolute inset-0 bg-gradient-to-t from-brand-900 to-transparent"></div>
                    <div class="relative z-10">
                        <div class="w-12 h-12 bg-white/10 backdrop-blur-md rounded-2xl flex items-center justify-center mb-6 border border-white/20">
                            <i class="ph-fill ph-lightning text-2xl text-accent"></i>
                        </div>
                        <h4 class="text-xl font-bold mb-2">Home & Appliances</h4>
                        <p class="text-brand-100 text-sm font-medium">Modern solutions for your modern home.</p>
                    </div>
                </div>

                <!-- Box 3 (Small) -->
                <div class="bg-accent rounded-[2rem] p-8 md:p-10 shadow-sm flex flex-col justify-between group overflow-hidden relative" data-aos="fade-up" data-aos-delay="300">
                    <div class="absolute right-[-20%] bottom-[-20%] opacity-10 group-hover:scale-110 transition-transform duration-500">
                        <i class="ph-fill ph-shopping-bag text-[10rem] text-brand-900"></i>
                    </div>
                    <div class="relative z-10">
                        <div class="w-12 h-12 bg-white/60 rounded-2xl flex items-center justify-center mb-6 shadow-sm">
                            <i class="ph-fill ph-shopping-cart text-2xl text-brand-900"></i>
                        </div>
                        <h4 class="text-xl font-bold text-brand-900 mb-2">All Essentials</h4>
                        <p class="text-brand-800 text-sm font-medium">From staples to home appliances, in one place.</p>
                    </div>
                </div>

                <!-- Box 4 (Large) -->
                <div class="md:col-span-2 bg-white rounded-[2rem] p-8 md:p-10 border border-gray-100 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_20px_40px_rgb(0,0,0,0.08)] transition-all duration-500 flex flex-col justify-between group overflow-hidden relative" data-aos="fade-up" data-aos-delay="400">
                    <div class="absolute right-0 bottom-0 w-full md:w-1/2 h-full bg-gradient-to-t md:bg-gradient-to-l from-brand-50 to-transparent opacity-50 md:opacity-100"></div>
                    <div class="relative z-10">
                        <div class="w-14 h-14 bg-brand-50 rounded-2xl flex items-center justify-center mb-6">
                            <i class="ph-fill ph-lightning text-3xl text-brand-DEFAULT"></i>
                        </div>
                        <h4 class="text-2xl font-bold text-brand-900 mb-3">Fast & Convenient</h4>
                        <p class="text-gray-600 font-medium max-w-md">No more long queues or store visits. Order quickly on our app and get it delivered at lightning speed.</p>
                    </div>
                    <div class="absolute right-[-5%] bottom-[-20%] opacity-[0.03] md:opacity-10 group-hover:scale-110 transition-transform duration-700 pointer-events-none">
                        <i class="ph-fill ph-timer text-[12rem] text-brand-DEFAULT"></i>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- 3. PRODUCTS (Sleek Horizontal/Grid) -->
    <section id="products" class="py-20 md:py-32 bg-white relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 md:mb-16" data-aos="fade-up">
                <div class="max-w-2xl">
                    <h2 class="text-3xl md:text-5xl font-extrabold text-brand-900 tracking-tight mb-4 leading-tight">Everything You Need.</h2>
                    <p class="text-base md:text-lg text-gray-600 font-medium">Browse our wide range of carefully selected products, updated daily.</p>
                </div>
                <a href="#app" class="inline-flex items-center gap-2 text-brand-DEFAULT font-bold hover:text-brand-900 transition-colors group mt-6 md:mt-0">
                    View Full Catalog 
                    <div class="w-8 h-8 rounded-full bg-brand-50 flex items-center justify-center group-hover:bg-accent transition-colors">
                        <i class="ph-bold ph-arrow-right"></i>
                    </div>
                </a>
            </div>

            <!-- Modern Product Categories -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
                <!-- Card 1 -->
                <div class="group relative h-[300px] md:h-[400px] rounded-[2rem] overflow-hidden cursor-pointer bg-gray-100" data-aos="fade-up" data-aos-delay="100">
                    <img src="assets/grocery.png" loading="lazy" alt="Daily Staples" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                    <div class="absolute inset-0 p-6 md:p-8 flex flex-col justify-end">
                        <div class="w-10 h-10 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center mb-4 transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
                            <i class="ph-bold ph-plus text-white"></i>
                        </div>
                        <h4 class="text-white text-xl md:text-2xl font-bold mb-1">Daily Staples</h4>
                        <p class="text-white/80 text-xs md:text-sm font-medium">Rice, Dal & Essentials</p>
                    </div>
                </div>

                <!-- Card 2 -->
                <div class="group relative h-[300px] md:h-[400px] rounded-[2rem] overflow-hidden cursor-pointer bg-gray-100" data-aos="fade-up" data-aos-delay="200">
                    <img src="assets/appliances.png" loading="lazy" alt="Home Appliances" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                    <div class="absolute inset-0 p-6 md:p-8 flex flex-col justify-end">
                        <div class="w-10 h-10 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center mb-4 transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
                            <i class="ph-bold ph-plus text-white"></i>
                        </div>
                        <h4 class="text-white text-xl md:text-2xl font-bold mb-1">Home Appliances</h4>
                        <p class="text-white/80 text-xs md:text-sm font-medium">Kitchen & Modern Living</p>
                    </div>
                </div>

                <!-- Card 3 -->
                <div class="group relative h-[300px] md:h-[400px] rounded-[2rem] overflow-hidden cursor-pointer bg-gray-100" data-aos="fade-up" data-aos-delay="300">
                    <img src="assets/electronics.png" loading="lazy" alt="Electronics" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                    <div class="absolute inset-0 p-6 md:p-8 flex flex-col justify-end">
                        <div class="w-10 h-10 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center mb-4 transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
                            <i class="ph-bold ph-plus text-white"></i>
                        </div>
                        <h4 class="text-white text-xl md:text-2xl font-bold mb-1">Electronics</h4>
                        <p class="text-white/80 text-xs md:text-sm font-medium">Gadgets & Devices</p>
                    </div>
                </div>

                <!-- Card 4 (FIXED IMAGE) -->
                <div class="group relative h-[300px] md:h-[400px] rounded-[2rem] overflow-hidden cursor-pointer bg-gray-100" data-aos="fade-up" data-aos-delay="400">
                    <!-- Updated reliable Unsplash image for household/cleaning products -->
                    <img src="https://images.unsplash.com/photo-1584824486509-11459466a200?auto=format&fit=crop&w=600&q=80" loading="lazy" alt="Household Essentials" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
